# Release secrets. Copy this file to `.env.release` (gitignored) and fill in your
# real values — `npm run release` / `npm run dist` auto-load it, so you never have
# to re-type `export …` in each terminal.
#
#   cp .env.release.example .env.release   then edit .env.release

# GitHub token with 'repo' scope — used only to upload the release.
GH_TOKEN=ghp_your_token_here

# Apple notarization (Developer ID). Without these, the build is signed but NOT
# notarized (Gatekeeper will warn on a downloaded copy).
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=abcd-efgh-ijkl-mnop
APPLE_TEAM_ID=K7VM2MP885
